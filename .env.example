# Telegram
TELEGRAM_BOT_TOKEN=

# LLM Provider (claude | gpt | deepseek | ollama | openrouter | groq | deepsproxy)
LLM_PROVIDER=openrouter

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT
OPENAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=cognitivecomputations/dolphin-mistral-24b-venice-edition:free

# DeepSeek
DEEPSEEK_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# DeepSProxy (local proxy for DeepSeek)
DEEPSPROXY_BASE_URL=http://localhost:3000/v1
DEEPSPROXY_API_KEY=
DEEPSPROXY_MODEL=deepseek-v4-flash

# Vector Store (pinecone | local)
VECTOR_STORE=local
PINECONE_API_KEY=
PINECONE_INDEX=

# Voice (openai | local)
STT_PROVIDER=openai
TTS_PROVIDER=openai

# Cost limits (USD)
DAILY_COST_LIMIT=2.00

# N8N Webhook (Composio mode — delegar tools para n8n)
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=
N8N_TIMEOUT_MS=60000
N8N_MAX_RETRIES=2

# Planner DAG (planejamento multi-step)
PLANNER_ENABLED=true
PLANNER_MAX_TASKS=6

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_MS=60000

# Safety: approval system for destructive actions
APPROVALS_ENABLED=true
APPROVAL_TIMEOUT=120000
