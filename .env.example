# Telegram
TELEGRAM_BOT_TOKEN=

# LLM Provider (claude | gpt | deepseek | ollama | qwenproxy)
LLM_PROVIDER=claude

# QwenProxy (local Qwen proxy via Playwright)
QWENPROXY_MODEL=qwen3.7-plus

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Vector Store (pinecone | local)
VECTOR_STORE=local
PINECONE_API_KEY=
PINECONE_INDEX=

# Voice (openai | local)
STT_PROVIDER=openai
TTS_PROVIDER=openai

# Cost limits (USD)
DAILY_COST_LIMIT=2.00
