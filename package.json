{
  "name": "agent-office",
  "version": "1.0.0",
  "description": "Personal AI agent running on Telegram",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n deepsproxy,agent -c cyan,magenta \"npm run dev:proxy\" \"tsx watch src/index.ts\"",
    "dev:proxy": "tsx watch deepsproxy/src/index.ts",
    "start": "concurrently -n deepsproxy,agent \"npm run start:proxy\" \"node --loader ts-node/esm src/index.ts\"",
    "start:proxy": "tsx deepsproxy/src/index.ts",
    "login:deepseek": "tsx deepsproxy/src/login.ts",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && npm run clean:deepseek",
    "clean:deepseek": "tsx scripts/clean-deepseek-chats.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "iniciar": "pm2 start pm2.config.cjs && pm2 logs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@pinecone-database/pinecone": "^4.0.0",
    "archiver": "^8.0.0",
    "better-sqlite3": "^11.6.0",
    "cheerio": "^1.0.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "grammy": "^1.27.0",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.3",
    "openai": "^4.73.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.61.0",
    "telegraf": "^4.16.3",
    "tesseract.js": "^7.0.0",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^1.5.0"
  }
}
